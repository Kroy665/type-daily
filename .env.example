# Database Configuration
# PostgreSQL connection string
# Format: postgresql://[username]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://user:password@localhost:5432/typedaily

# NextAuth Configuration
# REQUIRED: Secret key for encrypting JWT tokens
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# REQUIRED: The canonical URL of your site
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# Google OAuth Configuration
# Get these from: https://console.cloud.google.com/
# REQUIRED: Google OAuth Client ID
GOOGLE_CLIENT_ID=your-google-client-id

# REQUIRED: Google OAuth Client Secret
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Node Environment
# Options: development | production | test
NODE_ENV=development

# Admin Configuration
# Comma-separated list of admin email addresses
# These users will have access to text management features
ADMIN_EMAILS=admin@example.com,another-admin@example.com

# Optional: Error Tracking (Sentry)
# SENTRY_DSN=your-sentry-dsn

# Optional: Redis Cache
# REDIS_URL=redis://localhost:6379

# Optional: Logging Level
# LOG_LEVEL=info
